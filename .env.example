# Corretor Pro — variáveis de ambiente
# (defina no Vercel: Project Settings → Environment Variables)

# --- Supabase (persistência dos leads/atendimentos + storage do ZIP) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# alias usado por alguns módulos do cérebro; pode repetir o mesmo SUPABASE_URL
NEXT_PUBLIC_SUPABASE_URL=

# --- OpenAI (cérebro de IA: análise comercial + transcrição de áudio) ---
OPENAI_API_KEY=
# opcionais (deixe em branco se não usar gateway/projeto/org dedicados)
OPENAI_BASE_URL=
OPENAI_PROJECT=
OPENAI_ORGANIZATION=

# --- Ajustes opcionais do cérebro orquestrado ---
# CEREBRO_ORQUESTRADO=1
# MAX_AUDIO_TRANSCRIPTIONS=20
# DIRECIONA_LIMITAR_HISTORICO=
# DIRECIONA_USAR_APRENDIZADO_AUTO=
# DIRECIONA_USAR_CONHECIMENTO_AUTO=
# DIRECIONA_USAR_ESTILO_AUTO=
